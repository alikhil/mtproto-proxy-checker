# MTProto Proxy Configuration
# Rename this file to .env and fill in your values

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Chat ID where to send notifications
# Use: docker run --rm -e BOT_TOKEN=your_token mtproto-checker python3 /app/checker.py --get-chat-id
CHAT_ID=your_chat_id_here

# Proxy settings - Option 1: Use PROXY_URL (recommended)
# Full proxy URL in Telegram format
PROXY_URL=tg://proxy?server=example.com&port=443&secret=ee00000000000000000000000000000000

# Proxy settings - Option 2: Use individual settings
# Only needed if PROXY_URL is not set
# PROXY_HOST=your_proxy_host
# PROXY_PORT=443
# PROXY_SECRET=your_proxy_secret

# Check interval in seconds (default: 300 = 5 minutes)
CHECK_INTERVAL=300
